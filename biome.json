{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!dist", "!.claude", "!node_modules"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							{ "type": true, "source": [":URL:", ":NODE:"] },
							[":URL:", ":NODE:"],
							":BLANK_LINE:",
							[{ "type": true, "source": [":PACKAGE:"] }],
							":PACKAGE:",
							":BLANK_LINE:",
							{ "type": true, "source": ["@/**"] },
							["@/**"],
							":BLANK_LINE:",
							{
								"type": true,
								"source": ["../../**", "../../../**", "../../../../**"]
							},
							["../../**", "../../../**", "../../../../**"],
							":BLANK_LINE:",
							{ "type": true, "source": ["../**"] },
							["../**"],
							":BLANK_LINE:",
							{ "type": true, "source": ["./**"] },
							["./**"]
						]
					}
				}
			}
		}
	}
}
